# terraform.tfvars.example
# Copy to "terraform.tfvars" and edit. Terraform auto-loads terraform.tfvars and
# uses these to override the defaults in variables.tf. terraform.tfvars is
# git-ignored so your personal values (like your IP) are not committed.
#
#   cp terraform.tfvars.example terraform.tfvars

aws_region   = "us-east-1"
project_name = "two-tier-demo"
environment  = "dev"

# Free Tier compute. t2.micro (or t3.micro) — both give 750 free hrs/month.
instance_type = "t2.micro"

# SECURITY: lock SSH to your own IP. Find it with:  curl ifconfig.me
# Then set e.g. "203.0.113.25/32". Leaving 0.0.0.0/0 exposes SSH to the world.
ssh_allowed_cidr = "0.0.0.0/0"

# Leave EKS OFF for Free Tier. Set true only if you accept ~$73/month.
enable_eks = false
