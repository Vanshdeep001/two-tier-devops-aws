# .env.example
# A TEMPLATE of the environment variables the backend understands.
# Copy this to ".env" for local dev:  cp .env.example .env
# NEVER commit the real ".env" (it is git-ignored). In Kubernetes these values
# come from a ConfigMap (non-secret) or a Secret (sensitive).

PORT=5000
# Which frontend origin may call this API. Use "*" locally; lock it down in prod.
CORS_ORIGIN=*
# The greeting text returned by GET /api/message.
MESSAGE=Hello from the Node.js + Express backend!
# Shown by GET /api/info. CI overrides this with the Git SHA at deploy time.
APP_VERSION=dev
