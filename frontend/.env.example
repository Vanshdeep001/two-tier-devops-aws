# frontend/.env.example
# Template of build-time env vars for the React app.
# Copy to ".env" for local dev:  cp .env.example .env
#
# IMPORTANT: React runs in the browser, so these are baked in at BUILD time, not
# read at runtime. Every variable the browser uses MUST start with REACT_APP_.

# Where the frontend sends API calls during `npm start` (local dev).
# In production we leave this as /api and let Nginx proxy to the backend.
REACT_APP_API_URL=http://localhost:5000/api
